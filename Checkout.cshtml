@model myntra.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
}

<h2 class="mb-4">Checkout</h2>

<form asp-action="Checkout" method="post" class="card p-4 shadow-sm">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

    <div class="mb-3">
        <label asp-for="ShippingAddress" class="form-label"></label>
        <input asp-for="ShippingAddress" class="form-control" />
        <span asp-validation-for="ShippingAddress" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Place Order</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
